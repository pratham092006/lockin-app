 an effect body causes cascading renders that can hurt performance, and is not recommended. (https://react.dev/learn/you-might-not-need-an-effect).\n\n  45 |\n  46 |   useEffect(() => { \n> 47 |     setIsClient(true);\n     |     ^^^^^^^^^^^ Avoid calling setState() directly within an effect\n  48 |     const t = setTimeout(() => setGaugeReady(true), 100); \n  49 |     return () => clearTimeout(t); \n  50 |   }, []);",["246"],"'byDate' is assigned a value but never used. Allowed unused vars must match /^[A-Z_]/u.",["247"],"react-hooks/purity","Error: Cannot call impure function during render\n\n`Math.random` is an impure function. Calling an impure function can produce unstable results that update unpredictably when the component happens to re-render. (https://react.dev/reference/rules/components-and-hooks-must-be-pure#components-and-hooks-must-be-idempotent).\n\n  349 |                 {Array.from({ length: 31 }, (_, i) => i + 1).map(day => {\n  350 |                   const isToday = day === new Date().getDate();\n> 351 |                   const isSuccess = day < isToday && Math.random() > 0.3;\n      |                                                      ^^^^^^^^^^^^^ Cannot call impure function\n  352 |                   \n  353 |                   return (\n  354 |                     <div key={day} className={cn(",["248"],"'err' is defined but never used.",["249"],["250"],["251"],["252"],["253"],{"messageId":"254","data":"255","fix":"256","desc":"257"},{"messageId":"254","data":"258","fix":"259","desc":"257"},{"messageId":"254","data":"260","fix":"261","desc":"262"},{"messageId":"254","data":"263","fix":"264","desc":"265"},{"messageId":"254","data":"266","fix":"267","desc":"257"},{"messageId":"254","data":"268","fix":"269","desc":"257"},{"messageId":"254","data":"270","fix":"271","desc":"257"},{"messageId":"254","data":"272","fix":"273","desc":"274"},{"messageId":"254","data":"275","fix":"276","desc":"257"},{"kind":"277","justification":"278"},{"messageId":"25